PORT=4000
NODE_ENV=development
DATABASE_URL=postgres://postgres:postgres@localhost:5432/rr_digital_app

# Minimum 32 characters each. Generate with: openssl rand -hex 32
JWT_ACCESS_SECRET=change_me_access_secret_must_be_at_least_32_chars
JWT_REFRESH_SECRET=change_me_refresh_secret_must_be_at_least_32_chars
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL_DAYS=30

# Comma-separated list of allowed origins, or "*" for wildcard (dev only).
# In staging/prod set the exact allowed origin(s), e.g.:
#   CORS_ORIGIN=https://app.example.com
CORS_ORIGIN=*

# Auth rate limit (per IP, sliding window).
# Applies to POST /api/auth/login and POST /api/auth/refresh only.
AUTH_RATE_LIMIT_WINDOW_MS=900000
AUTH_RATE_LIMIT_MAX=20

# Trust proxy hops. 0 = direct connection (default).
# Set to 1 when the API runs behind a single reverse proxy (e.g. Nginx on the same host).
TRUST_PROXY=0


# Pasta House integration (optional).
# Required only when the restaurant_orders module is active for a company.
# PASTA_HOUSE_COMPANY_ID: UUID of the Pasta House company row in this DB.
# PASTA_HOUSE_INTERNAL_API_BASE_URL: base URL of the Pasta House internal API endpoint.
# PASTA_HOUSE_INTERNAL_TOKEN: shared secret. Generate with: openssl rand -hex 32.
# PASTA_HOUSE_INTERNAL_API_BASE_URL=https://pasta-house.example.com/api/internal/rr-digital
# PASTA_HOUSE_INTERNAL_TOKEN=change_me_internal_token_min_32_chars
# PASTA_HOUSE_COMPANY_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
