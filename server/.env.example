PORT=4000
NODE_ENV=development
DATABASE_URL=postgres://postgres:postgres@localhost:5432/rr_digital_app

JWT_ACCESS_SECRET=replace_with_access_secret
JWT_REFRESH_SECRET=replace_with_refresh_secret
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL_DAYS=30

# Comma-separated list of allowed origins, or "*" for wildcard (dev only).
# In staging/prod set the exact allowed origin(s), e.g.:
#   CORS_ORIGIN=https://app.example.com
CORS_ORIGIN=*

# Auth rate limit (per IP, sliding window).
# Applies to POST /api/auth/login and POST /api/auth/refresh only.
AUTH_RATE_LIMIT_WINDOW_MS=900000
AUTH_RATE_LIMIT_MAX=20

# Trust proxy hops. 0 = direct connection (default).
# Set to 1 when the API runs behind a single reverse proxy (e.g. Nginx on the same host).
TRUST_PROXY=0
